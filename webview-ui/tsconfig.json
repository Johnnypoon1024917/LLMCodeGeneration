{
    "//": [
        "Webview-side TypeScript config. The backend has its own tsconfig at",
        "the repo root that EXCLUDES this directory, so without this file the",
        "webview source had no type-checking step — `npx tsc --noEmit` from",
        "this directory would silently find zero files to check (the React",
        "#310 hooks-ordering bug shipped because of exactly this gap).",
        "",
        "Vite handles transformation regardless of tsconfig. This config is",
        "purely for type-checking via `npx tsc --noEmit`. Strict mode mirrors",
        "the backend's settings so the codebase has consistent type-safety",
        "expectations across both runtimes."
    ],
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "types": ["vite/client", "node", "@testing-library/jest-dom"],
        "strict": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "noEmit": true,
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitOverride": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "noPropertyAccessFromIndexSignature": true,
        "paths": {
            "@i18n-locales/*": ["../src/i18n/locales/*"]
        },
        "allowImportingTsExtensions": false
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "vite.config.ts",
        "vitest.config.ts"
    ],
    "exclude": [
        "node_modules",
        "build"
    ]
}