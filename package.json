{
  "name": "nexuscode",
  "displayName": "NexusCode",
  "publisher": "your-publisher-id",
  "description": "%extension.description%",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "main": "./out/extension.js",
  "bin": {
    "nexuscode": "./out/cli.js"
  },
  "contributes": {
    "configuration": {
      "title": "NexusCode",
      "properties": {
        "nexuscode.apiEndpoint": {
          "type": "string",
          "default": "http://192.168.192.125:8001/v1/chat/completions",
          "description": "%configuration.nexuscode.apiEndpoint.description%"
        },
        "nexuscode.model": {
          "type": "string",
          "default": "qwen2.5-coder",
          "description": "%configuration.nexuscode.model.description%"
        },
        "nexuscode.modelPlanner": {
          "type": "string",
          "default": "",
          "description": "Model identifier for the Planner agent. Leave empty to use the global `nexuscode.model`. Set to a stronger reasoning model (e.g. DeepSeek V4 Pro) when you want to upgrade plan quality without paying for it on every Coder invocation."
        },
        "nexuscode.modelCoder": {
          "type": "string",
          "default": "",
          "description": "Model identifier for the Coder agent. Leave empty to use the global `nexuscode.model`. Set to a faster/cheaper model (e.g. DeepSeek V4 Flash) for per-step code generation when the global default is reserved for Planner."
        },
        "nexuscode.modelVerifier": {
          "type": "string",
          "default": "",
          "description": "Model identifier for the Verifier agent (PRD-review LLM call). Leave empty to use the global `nexuscode.model`. Verification is short, deterministic, and tolerant of smaller/faster models \u2014 useful for cost optimization."
        },
        "nexuscode.apiKey": {
          "type": "string",
          "default": "",
          "description": "%configuration.nexuscode.apiKey.description%"
        },
        "nexuscode.maxVerificationRetries": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 5,
          "description": "%configuration.nexuscode.maxVerificationRetries.description%"
        },
        "nexuscode.rateLimits.maxToolCallsPerTask": {
          "type": "number",
          "default": 100,
          "minimum": 0,
          "description": "Hard cap on the total number of tool calls (read_file, write_file, bash_exec, etc.) the agent may make within a single task. Subsequent calls are rejected with an error result, preventing runaway agents from hammering the workspace. Set to 0 to reject all tool calls (debugging only). Default 100 — typical tasks complete in 10-30 calls; the cap accommodates complex multi-file edits with headroom."
        },
        "nexuscode.rateLimits.perTool": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "number",
            "minimum": 0
          },
          "description": "Per-tool call limits within a single task. Map of tool name (e.g. \"bash_exec\", \"write_file\") to maximum calls. Tools not listed here are governed only by `rateLimits.maxToolCallsPerTask`. Example: {\"bash_exec\": 10, \"write_file\": 30}. Use this to constrain the most dangerous tools more tightly than the overall cap."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nexuscode-activitybar",
          "title": "%viewContainer.nexuscode-activitybar.title%",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "nexuscode-activitybar": [
        {
          "type": "webview",
          "id": "nexuscode.sidebar",
          "name": "NexusCode"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "nexuscode.optimizeSelection",
          "group": "navigation",
          "when": "editorHasSelection"
        },
        {
          "submenu": "nexuscode.submenu",
          "when": "editorHasSelection",
          "group": "1_modification"
        }
      ],
      "nexuscode.submenu": [
        {
          "command": "nexuscode.addSelection",
          "group": "1_actions@1"
        },
        {
          "command": "nexuscode.explainSelection",
          "group": "1_actions@2"
        },
        {
          "command": "nexuscode.modifySelection",
          "group": "1_actions@3"
        }
      ]
    },
    "commands": [
      {
        "command": "nexuscode.inlineEdit",
        "title": "%command.nexuscode_inlineEdit.title%"
      },
      {
        "command": "nexuscode.optimizeSelection",
        "title": "%command.nexuscode_optimizeSelection.title%"
      },
      {
        "command": "nexuscode.addSelection",
        "title": "%command.nexuscode_addSelection.title%"
      },
      {
        "command": "nexuscode.explainSelection",
        "title": "%command.nexuscode_explainSelection.title%"
      },
      {
        "command": "nexuscode.modifySelection",
        "title": "%command.nexuscode_modifySelection.title%"
      },
      {
        "command": "nexuscode.setApiKey",
        "title": "%command.nexuscode_setApiKey.title%"
      },
      {
        "command": "nexuscode.runHook",
        "title": "%command.nexuscode_runHook.title%"
      },
      {
        "command": "nexuscode.acceptEdit",
        "title": "%command.nexuscode_acceptEdit.title%",
        "category": "NexusCode",
        "enablement": "false"
      },
      {
        "command": "nexuscode.rejectEdit",
        "title": "%command.nexuscode_rejectEdit.title%",
        "category": "NexusCode",
        "enablement": "false"
      },
      {
        "command": "nexuscode.refreshLens",
        "title": "%command.nexuscode_refreshLens.title%",
        "category": "NexusCode",
        "enablement": "false"
      },
      {
        "command": "nexuscode.viewDiff",
        "title": "%command.nexuscode_viewDiff.title%",
        "category": "NexusCode",
        "enablement": "false"
      },
      {
        "command": "nexuscode.reviewCode",
        "title": "%command.nexuscode_reviewCode.title%",
        "category": "NexusCode",
        "enablement": "false"
      }
    ],
    "submenus": [
      {
        "id": "nexuscode.submenu",
        "label": "NexusCode"
      }
    ],
    "keybindings": [
      {
        "command": "nexuscode.inlineEdit",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "validate": "node scripts/validate-manifest.js",
    "compile": "npm run validate && tsc -p ./",
    "vscode:prepublish": "npm run compile",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:unit": "jest --config jest.config.js"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "i18next": "^26.0.8"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}