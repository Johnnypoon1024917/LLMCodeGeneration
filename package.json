{
  "name": "nexuscode",
  "displayName": "NexusCode",
  "publisher": "your-publisher-id",
  "description": "Spec-driven AI coding assistant — requirements, design, tasks, and implementation in one IDE workflow.",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "NexusCode",
      "properties": {
        "nexuscode.apiEndpoint": {
          "type": "string",
          "default": "http://192.168.192.125:8001/v1/chat/completions",
          "description": "OpenAI-compatible /v1/chat/completions endpoint (LM Studio, Ollama, vLLM, OpenAI, etc.)."
        },
        "nexuscode.model": {
          "type": "string",
          "default": "qwen2.5-coder",
          "description": "The name or path of the model to use."
        },
        "nexuscode.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key (leave empty for local servers). Prefer the 'NexusCode: Set API Key' command — keys are stored in VS Code SecretStorage, not settings.json."
        },
        "nexuscode.enableTools": {
          "type": "boolean",
          "default": true,
          "description": "Enable function-calling tools for the planner and explorer agents. Disable only if your local server (older vLLM) does not parse tool_calls."
        },
        "nexuscode.maxVerificationRetries": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 5,
          "description": "Maximum times the Verifier may reject and re-prompt the Coder per file."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nexuscode-activitybar",
          "title": "NexusCode",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "nexuscode-activitybar": [
        {
          "type": "webview",
          "id": "nexuscode.sidebar",
          "name": "NexusCode"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "nexuscode.optimizeSelection",
          "group": "navigation",
          "when": "editorHasSelection"
        },
        {
          "submenu": "nexuscode.submenu",
          "when": "editorHasSelection",
          "group": "1_modification"
        }
      ],
      "nexuscode.submenu": [
        {
          "command": "nexuscode.addSelection",
          "group": "1_actions@1"
        },
        {
          "command": "nexuscode.explainSelection",
          "group": "1_actions@2"
        },
        {
          "command": "nexuscode.modifySelection",
          "group": "1_actions@3"
        }
      ]
    },
    "commands": [
      {
        "command": "nexuscode.inlineEdit",
        "title": "NexusCode: Inline Edit (Cmd/Ctrl + Shift + K)"
      },
      {
        "command": "nexuscode.optimizeSelection",
        "title": "NexusCode: Optimize Selection"
      },
      {
        "command": "nexuscode.addSelection",
        "title": "NexusCode: Add Selection to Chat"
      },
      {
        "command": "nexuscode.explainSelection",
        "title": "NexusCode: Explain Selected Code"
      },
      {
        "command": "nexuscode.modifySelection",
        "title": "NexusCode: Modify Selected Code"
      },
      {
        "command": "nexuscode.setApiKey",
        "title": "NexusCode: Set API Key"
      },
      {
        "command": "nexuscode.runHook",
        "title": "NexusCode: Run Hook"
      },
      {
        "command": "nexuscode.acceptEdit",
        "title": "NexusCode: Accept AI Edit",
        "category": "NexusCode",
        "enablement": "false"
      },
      {
        "command": "nexuscode.rejectEdit",
        "title": "NexusCode: Reject AI Edit",
        "category": "NexusCode",
        "enablement": "false"
      },
      {
        "command": "nexuscode.refreshLens",
        "title": "NexusCode: Refresh CodeLens",
        "category": "NexusCode",
        "enablement": "false"
      },
      {
        "command": "nexuscode.viewDiff",
        "title": "NexusCode: View AI Diff",
        "category": "NexusCode",
        "enablement": "false"
      },
      {
        "command": "nexuscode.reviewCode",
        "title": "NexusCode: Review Generated Code",
        "category": "NexusCode",
        "enablement": "false"
      }
    ],
    "submenus": [
      {
        "id": "nexuscode.submenu",
        "label": "NexusCode"
      }
    ],
    "keybindings": [
      {
        "command": "nexuscode.inlineEdit",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "validate": "node scripts/validate-manifest.js",
    "compile": "npm run validate && tsc -p ./",
    "vscode:prepublish": "npm run compile",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}