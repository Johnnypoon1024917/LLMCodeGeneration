{
  "name": "Andromeda",
  "displayName": "Andromeda",
  "description": "LLM code generation",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Andromeda Agent",
      "properties": {
        "nexuscode.apiEndpoint": {
          "type": "string",
          "default": "http://192.168.192.125:8001/v1/chat/completions",
          "description": "The URL of your LLM provider (e.g., LM Studio, vLLM, OpenAI, or your custom API Gateway)."
        },
        "nexuscode.model": {
          "type": "string",
          "default": "qwen2.5-coder",
          "description": "The name or path of the model to use."
        },
        "nexuscode.apiKey": {
          "type": "string",
          "default": "lm-studio",
          "description": "Your API Key (if using a cloud provider or authenticated gateway)."
        },
        "nexuscode.enableTools": {
          "type": "boolean",
          "default": false,
          "description": "Enable agent tools (sends tool_choice: 'auto'). Keep this unchecked if your local server (like vLLM) does not have tool-call parsing enabled."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "qwen-sidebar-view",
          "title": "Andromeda",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "qwen-sidebar-view": [
        {
          "type": "webview",
          "id": "qwen-sidebar",
          "name": "Coding Assistant",
          "icon": "media/icon.svg"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "nexuscode.optimizeSelection",
          "group": "navigation",
          "when": "editorHasSelection"
        },
        {
          "submenu": "nexuscode.submenu",
          "when": "editorHasSelection",
          "group": "1_modification"
        }
      ],
      "nexuscode.submenu": [
        {
          "command": "nexuscode.addSelection",
          "group": "1_actions@1"
        },
        {
          "command": "nexuscode.explainSelection",
          "group": "1_actions@2"
        },
        {
          "command": "nexuscode.modifySelection",
          "group": "1_actions@3"
        }
      ]
    },
    "commands": [
      {
        "command": "nexuscode.inlineEdit",
        "title": "NexusCode: Inline Edit (Cmd/Ctrl + Shift + K)"
      },
      {
        "command": "nexuscode.optimizeSelection",
        "title": "Qwen: Optimize Selection"
      },
      {
        "command": "nexuscode.addSelection",
        "title": "Add Selection to Chat"
      },
      {
        "command": "nexuscode.explainSelection",
        "title": "Explain Selected Code"
      },
      {
        "command": "nexuscode.modifySelection",
        "title": "Modify Selected Code"
      }
    ],
    "submenus": [
      {
        "id": "nexuscode.submenu",
        "label": "NexusCode"
      }
    ],
    "keybindings": [
      {
        "command": "nexuscode.inlineEdit",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
